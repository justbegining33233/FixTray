generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DATABASE_URL_UNPOOLED")
}

model Customer {
  id                  String               @id @default(cuid())
  username            String?              @unique
  email               String               @unique
  password            String
  firstName           String
  lastName            String
  phone               String?
  company             String?
  stripeCustomerId    String?              @unique
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  emailVerified       Boolean              @default(true)
  emailVerifiedAt     DateTime?
  internalNotes       String?
  tags                String?
  appointments        Appointment[]
  documents           CustomerDocument[]
  messages            CustomerMessage[]
  favoriteShops       FavoriteShop[]
  notifications       Notification[]
  paymentMethods      PaymentMethod[]
  recurringWorkOrders RecurringWorkOrder[]
  reviews             Review[]
  rewardClaims        RewardClaim[]
  vehicles            Vehicle[]
  workOrders          WorkOrder[]

  @@map("customers")
}

model VerificationToken {
  id        String   @id @default(cuid())
  userId    String
  type      String
  tokenHash String   @unique
  expiresAt DateTime
  metadata  String?
  createdAt DateTime @default(now())

  @@index([userId])
  @@map("verification_tokens")
}

model RewardClaim {
  id         String    @id @default(cuid())
  customerId String
  tierId     String
  status     String    @default("pending")
  claimedAt  DateTime  @default(now())
  redeemedAt DateTime?
  expiresAt  DateTime
  customer   Customer  @relation(fields: [customerId], references: [id])

  @@index([customerId])
  @@map("reward_claims")
}

model Shop {
  id                  String                   @id @default(cuid())
  username            String                   @unique
  password            String
  shopName            String
  ownerName           String?
  email               String
  phone               String
  zipCode             String
  address             String?
  city                String?
  state               String?
  businessLicense     String?
  insurancePolicy     String?
  shopType            String?
  profileComplete     Boolean                  @default(false)
  capacity            Int                      @default(1)
  slotDuration        Int                      @default(30)
  status              String                   @default("pending")
  createdAt           DateTime                 @default(now())
  updatedAt           DateTime                 @updatedAt
  approvedAt          DateTime?
  stripeAccountId     String?
  twoFactorEnabled    Boolean                  @default(false)
  twoFactorSecret     String?
  emailVerified       Boolean                  @default(true)
  emailVerifiedAt     DateTime?
  appointments        Appointment[]
  automationRules     AutomationRule[]
  bays                Bay[]
  campaigns           Campaign[]
  coreReturns         CoreReturn[]
  dviInspections      DVIInspection[]
  environmentalFees   EnvironmentalFee[]
  fleetAccounts       FleetAccount[]
  integrations        IntegrationConfig[]
  inventory           InventoryItem[]
  leaveRequests       LeaveRequest[]
  loanerVehicles      LoanerVehicle[]
  overtimeRule        OvertimeRule?
  payPeriods          PayPeriod[]
  payStubs            PayStub[]
  paymentLinks        PaymentLink[]
  purchaseOrders      PurchaseOrder[]
  recurringWorkOrders RecurringWorkOrder[]
  referrals           Referral[]
  reviews             Review[]
  shiftSwapRequests   ShiftSwapRequest[]
  shifts              Shift[]
  blockedDates        ShopBlockedDate[]
  shopLaborRates      ShopLaborRate[]
  shopLocations       ShopLocation[]
  monthlyReports      ShopMonthlyReport[]
  schedules           ShopSchedule[]
  services            ShopService[]
  settings            ShopSettings?
  stateInspections    StateInspection[]
  taxRules            TaxRule[]
  techs               Tech[]
  conditionReports    VehicleConditionReport[]
  vendors             Vendor[]
  workAuthorizations  WorkAuthorization[]
  workOrders          WorkOrder[]
  workOrderTemplates  WorkOrderTemplate[]

  @@map("shops")
}

model ShopSchedule {
  id        String   @id @default(cuid())
  shopId    String
  dayOfWeek Int
  isOpen    Boolean  @default(true)
  openTime  String
  closeTime String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  shop      Shop     @relation(fields: [shopId], references: [id], onDelete: Cascade)

  @@unique([shopId, dayOfWeek])
  @@index([shopId])
  @@map("shop_schedules")
}

model ShopBlockedDate {
  id        String   @id @default(cuid())
  shopId    String
  date      DateTime
  reason    String?
  createdAt DateTime @default(now())
  shop      Shop     @relation(fields: [shopId], references: [id], onDelete: Cascade)

  @@unique([shopId, date])
  @@index([shopId])
  @@index([date])
  @@map("shop_blocked_dates")
}

model ShopService {
  id          String   @id @default(cuid())
  shopId      String
  serviceName String
  category    String
  price       Float?
  duration    Int?
  description String?
  createdAt   DateTime @default(now())
  shop        Shop     @relation(fields: [shopId], references: [id], onDelete: Cascade)

  @@unique([shopId, serviceName, category])
  @@index([shopId])
  @@map("shop_services")
}

model ShopLaborRate {
  id        String   @id @default(cuid())
  shopId    String
  name      String
  rate      Float
  category  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  shop      Shop     @relation(fields: [shopId], references: [id], onDelete: Cascade)

  @@index([shopId])
  @@map("shop_labor_rates")
}

model Tech {
  id                    String             @id @default(cuid())
  shopId                String
  email                 String             @unique
  password              String
  firstName             String
  lastName              String
  phone                 String?
  role                  String
  available             Boolean            @default(true)
  hourlyRate            Float              @default(0)
  latitude              Float?
  longitude             Float?
  locationAccuracy      Float?
  lastLocationUpdate    DateTime?
  createdAt             DateTime           @default(now())
  updatedAt             DateTime           @updatedAt
  bankAccountInfo       String?
  department            String?
  emergencyContact      String?
  employmentType        String             @default("full-time")
  hireDate              DateTime?
  jobTitle              String?
  overtimeRate          Float?
  payType               String             @default("hourly")
  salary                Float?
  taxWithholding        String?
  terminatedAt          DateTime?
  twoFactorEnabled      Boolean            @default(false)
  twoFactorSecret       String?
  leaveRequests         LeaveRequest[]
  payStubs              PayStub[]
  shiftSwapsAsRequester ShiftSwapRequest[] @relation("SwapRequester")
  shiftSwapsAsTarget    ShiftSwapRequest[] @relation("SwapTarget")
  shifts                Shift[]
  statusHistory         StatusHistory[]
  shop                  Shop               @relation(fields: [shopId], references: [id], onDelete: Cascade)
  timeEntries           TimeEntry[]
  assignedWorkOrders    WorkOrder[]

  @@index([shopId])
  @@map("techs")
}

model Vehicle {
  id                  String               @id @default(cuid())
  customerId          String
  vehicleType         String
  make                String?
  model               String?
  year                Int?
  vin                 String?
  licensePlate        String?
  createdAt           DateTime             @default(now())
  appointments        Appointment[]
  recurringWorkOrders RecurringWorkOrder[]
  customer            Customer             @relation(fields: [customerId], references: [id], onDelete: Cascade)
  workOrders          WorkOrder[]

  @@index([customerId])
  @@map("vehicles")
}

model WorkOrder {
  id                 String              @id @default(cuid())
  customerId         String
  shopId             String
  vehicleId          String?
  vehicleType        String
  serviceLocation    String
  issueDescription   String
  vinPhoto           String?
  assignedTechId     String?
  bay                Int?
  status             String              @default("pending")
  paymentStatus      String              @default("unpaid")
  paymentIntentId    String?
  amountPaid         Float?
  estimatedCost      Float?
  dueDate            DateTime?
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  completedAt        DateTime?
  repairs            Json?
  maintenance        Json?
  partsMaterials     Json?
  pictures           Json?
  location           Json?
  estimate           Json?
  techLabor          Json?
  partsUsed          Json?
  workPhotos         Json?
  completion         Json?
  customerMessages   CustomerMessage[]
  messages           Message[]
  purchaseOrderItems PurchaseOrderItem[]
  reviews            Review[]
  statusHistory      StatusHistory[]
  tracking           TechTracking?
  timeEntries        TimeEntry[]
  assignedTo         Tech?               @relation(fields: [assignedTechId], references: [id])
  customer           Customer            @relation(fields: [customerId], references: [id])
  shop               Shop                @relation(fields: [shopId], references: [id])
  vehicle            Vehicle?            @relation(fields: [vehicleId], references: [id])

  @@index([customerId])
  @@index([shopId])
  @@index([assignedTechId])
  @@index([status])
  @@index([paymentStatus])
  @@map("work_orders")
}

model StatusHistory {
  id          String    @id @default(cuid())
  workOrderId String
  fromStatus  String
  toStatus    String
  reason      String?
  changedById String?
  createdAt   DateTime  @default(now())
  changedBy   Tech?     @relation(fields: [changedById], references: [id])
  workOrder   WorkOrder @relation(fields: [workOrderId], references: [id], onDelete: Cascade)

  @@index([workOrderId])
  @@map("status_history")
}

model Message {
  id          String    @id @default(cuid())
  workOrderId String
  sender      String
  senderName  String
  body        String
  createdAt   DateTime  @default(now())
  workOrder   WorkOrder @relation(fields: [workOrderId], references: [id], onDelete: Cascade)

  @@index([workOrderId])
  @@map("messages")
}

model Notification {
  id             String    @id @default(cuid())
  customerId     String
  type           String
  title          String
  message        String
  read           Boolean   @default(false)
  readAt         DateTime?
  workOrderId    String?
  appointmentId  String?
  deliveryMethod String
  metadata       String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  customer       Customer  @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@index([customerId])
  @@index([read])
  @@index([type])
  @@index([createdAt])
  @@map("notifications")
}

model InventoryItem {
  id           String   @id @default(cuid())
  shopId       String
  type         String
  name         String
  sku          String?
  quantity     Int      @default(0)
  price        Float    @default(0)
  reorderPoint Int?
  rate         Float?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  shop         Shop     @relation(fields: [shopId], references: [id], onDelete: Cascade)

  @@index([shopId])
  @@map("inventory")
}

model PaymentMethod {
  id                    String   @id @default(cuid())
  customerId            String
  type                  String
  last4                 String
  brand                 String?
  expiryMonth           Int?
  expiryYear            Int?
  isDefault             Boolean  @default(false)
  stripePaymentMethodId String?
  createdAt             DateTime @default(now())
  customer              Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@index([customerId])
  @@map("payment_methods")
}

model ActivityLog {
  id        String   @id @default(cuid())
  type      String
  action    String
  details   String
  location  String?
  email     String?
  amount    String?
  severity  String
  user      String
  metadata  String?
  createdAt DateTime @default(now())
  shopId    String?

  @@index([type])
  @@index([createdAt])
  @@index([shopId])
  @@map("activity_logs")
}

model Admin {
  id            String         @id @default(cuid())
  username      String         @unique
  password      String
  email         String         @unique
  isSuperAdmin  Boolean        @default(false)
  createdAt     DateTime       @default(now())
  refreshTokens RefreshToken[]

  @@map("admins")
}

model RefreshToken {
  id        String    @id @default(cuid())
  tokenHash String
  adminId   String?
  createdAt DateTime  @default(now())
  expiresAt DateTime
  metadata  String?
  revoked   Boolean   @default(false)
  revokedAt DateTime?
  admin     Admin?    @relation(fields: [adminId], references: [id], onDelete: Cascade)

  @@index([revoked])
  @@map("refresh_tokens")
}

model TimeEntry {
  id            String     @id @default(cuid())
  techId        String
  shopId        String
  clockIn       DateTime
  clockOut      DateTime?
  breakStart    DateTime?
  breakEnd      DateTime?
  breakDuration Float?
  breaks        Json?
  workOrderId   String?
  isPto         Boolean    @default(false)
  approved      Boolean    @default(false)
  approvedBy    String?
  approvedAt    DateTime?
  locked        Boolean    @default(false)
  hoursWorked   Float?
  notes         String?
  location      String?
  clockInPhoto  String?
  clockOutPhoto String?
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
  tech          Tech       @relation(fields: [techId], references: [id], onDelete: Cascade)
  workOrder     WorkOrder? @relation(fields: [workOrderId], references: [id])

  @@index([techId])
  @@index([shopId])
  @@index([clockIn])
  @@index([workOrderId])
  @@map("time_entries")
}

model ShopSettings {
  id                       String   @id @default(cuid())
  shopId                   String   @unique
  defaultLaborRate         Float    @default(0)
  overtimeMultiplier       Float    @default(1.5)
  inventoryMarkup          Float    @default(0.30)
  businessHours            String?
  taxRate                  Float    @default(0)
  allowTimeTracking        Boolean  @default(true)
  requireClockInOut        Boolean  @default(false)
  gpsVerificationEnabled   Boolean  @default(false)
  shopLatitude             Float?
  shopLongitude            Float?
  gpsRadiusMeters          Int?     @default(100)
  weeklyPayrollBudget      Float?
  monthlyPayrollBudget     Float?
  notificationsEnabled     Boolean  @default(true)
  notificationSoundEnabled Boolean  @default(true)
  notificationPreferences  Json?
  createdAt                DateTime @default(now())
  updatedAt                DateTime @updatedAt
  require2FA               Boolean  @default(false)
  shop                     Shop     @relation(fields: [shopId], references: [id], onDelete: Cascade)

  @@map("shop_settings")
}

model InventoryRequest {
  id              String    @id @default(cuid())
  shopId          String
  requestedById   String
  itemName        String
  quantity        Int
  reason          String?
  urgency         String    @default("normal")
  status          String    @default("pending")
  approvedBy      String?
  approvedAt      DateTime?
  inventoryItemId String?
  orderDetails    String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([shopId])
  @@index([requestedById])
  @@index([status])
  @@map("inventory_requests")
}

model InventoryStock {
  id                 String              @id @default(cuid())
  shopId             String
  itemName           String
  sku                String?
  category           String?
  quantity           Int                 @default(0)
  unitCost           Float               @default(0)
  sellingPrice       Float               @default(0)
  reorderPoint       Int                 @default(10)
  reorderQuantity    Int                 @default(50)
  supplier           String?
  supplierSKU        String?
  location           String?
  lastRestocked      DateTime?
  notes              String?
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  purchaseOrderItems PurchaseOrderItem[]

  @@index([shopId])
  @@index([category])
  @@index([quantity])
  @@map("inventory_stock")
}

model PurchaseOrder {
  id                     String              @id @default(cuid())
  shopId                 String
  vendor                 String?
  status                 String              @default("ordered")
  expectedDate           DateTime?
  notes                  String?
  createdById            String?
  totalCost              Float?
  createdAt              DateTime            @default(now())
  updatedAt              DateTime            @updatedAt
  customerApprovalStatus String              @default("pending")
  items                  PurchaseOrderItem[]
  shop                   Shop                @relation(fields: [shopId], references: [id], onDelete: Cascade)

  @@index([shopId])
  @@map("purchase_orders")
}

model PurchaseOrderItem {
  id               String          @id @default(cuid())
  purchaseOrderId  String
  workOrderId      String?
  inventoryStockId String?
  itemName         String
  sku              String?
  quantity         Int
  unitCost         Float           @default(0)
  status           String          @default("ordered")
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
  inventoryStock   InventoryStock? @relation(fields: [inventoryStockId], references: [id])
  purchaseOrder    PurchaseOrder   @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)
  workOrder        WorkOrder?      @relation(fields: [workOrderId], references: [id])

  @@index([purchaseOrderId])
  @@index([workOrderId])
  @@index([inventoryStockId])
  @@map("purchase_order_items")
}

model AuditLog {
  id         String   @id @default(cuid())
  adminId    String
  action     String
  targetId   String?
  targetType String?
  details    String?
  ipAddress  String?
  userAgent  String?
  createdAt  DateTime @default(now())
  shopId     String?

  @@index([adminId])
  @@index([action])
  @@index([createdAt])
  @@index([shopId])
  @@map("audit_logs")
}

model DirectMessage {
  id           String    @id @default(cuid())
  senderId     String
  senderRole   String
  senderName   String
  receiverId   String
  receiverRole String
  receiverName String
  shopId       String?
  subject      String?
  body         String
  isRead       Boolean   @default(false)
  readAt       DateTime?
  threadId     String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@index([senderId, senderRole])
  @@index([receiverId, receiverRole])
  @@index([shopId])
  @@index([threadId])
  @@index([createdAt])
  @@map("direct_messages")
}

model Appointment {
  id            String            @id @default(cuid())
  customerId    String
  shopId        String
  vehicleId     String?
  scheduledDate DateTime
  serviceType   String
  notes         String?
  status        String            @default("scheduled")
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt
  customer      Customer          @relation(fields: [customerId], references: [id], onDelete: Cascade)
  shop          Shop              @relation(fields: [shopId], references: [id], onDelete: Cascade)
  vehicle       Vehicle?          @relation(fields: [vehicleId], references: [id])
  messages      CustomerMessage[]

  @@index([customerId])
  @@index([shopId])
  @@index([scheduledDate])
  @@index([status])
  @@map("appointments")
}

model Review {
  id             String    @id @default(cuid())
  customerId     String
  shopId         String
  workOrderId    String
  rating         Int
  comment        String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  shopResponse   String?
  shopResponseAt DateTime?
  customer       Customer  @relation(fields: [customerId], references: [id], onDelete: Cascade)
  shop           Shop      @relation(fields: [shopId], references: [id], onDelete: Cascade)
  workOrder      WorkOrder @relation(fields: [workOrderId], references: [id], onDelete: Cascade)

  @@unique([workOrderId, customerId])
  @@index([customerId])
  @@index([shopId])
  @@index([rating])
  @@map("reviews")
}

model FavoriteShop {
  id         String   @id @default(cuid())
  customerId String
  shopId     String
  createdAt  DateTime @default(now())
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@unique([customerId, shopId])
  @@index([customerId])
  @@map("favorite_shops")
}

model CustomerDocument {
  id          String   @id @default(cuid())
  customerId  String
  name        String
  type        String   @default("other")
  url         String
  fileSize    Int      @default(0)
  workOrderId String?
  uploadedAt  DateTime @default(now())
  customer    Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@index([customerId])
  @@index([workOrderId])
  @@map("customer_documents")
}

model CustomerMessage {
  id            String       @id @default(cuid())
  customerId    String
  workOrderId   String?
  appointmentId String?
  from          String
  content       String
  read          Boolean      @default(false)
  sentAt        DateTime     @default(now())
  appointment   Appointment? @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
  customer      Customer     @relation(fields: [customerId], references: [id], onDelete: Cascade)
  workOrder     WorkOrder?   @relation(fields: [workOrderId], references: [id], onDelete: Cascade)

  @@index([customerId])
  @@index([workOrderId])
  @@index([appointmentId])
  @@index([read])
  @@map("customer_messages")
}

model TechTracking {
  id               String    @id @default(cuid())
  workOrderId      String    @unique
  latitude         Float
  longitude        Float
  estimatedArrival DateTime?
  updatedAt        DateTime  @updatedAt
  workOrder        WorkOrder @relation(fields: [workOrderId], references: [id], onDelete: Cascade)

  @@index([workOrderId])
  @@map("tech_tracking")
}

model PushSubscription {
  id           String   @id @default(cuid())
  customerId   String   @unique
  subscription String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([customerId])
  @@map("push_subscriptions")
}

model PaymentHistory {
  id                    String    @id @default(cuid())
  subscriptionId        String?
  stripeInvoiceId       String?   @unique
  stripeSubscriptionId  String?
  stripePaymentIntentId String?
  amount                Float
  currency              String    @default("usd")
  status                String
  description           String?
  receiptUrl            String?
  paidAt                DateTime?
  createdAt             DateTime  @default(now())

  @@index([subscriptionId])
  @@index([stripeInvoiceId])
  @@map("payment_history")
}

model PageView {
  id        String   @id @default(cuid())
  path      String
  userAgent String?
  ipHash    String?
  sessionId String?
  referrer  String?
  createdAt DateTime @default(now())

  @@index([createdAt])
  @@index([path])
  @@map("page_views")
}

model RecurringWorkOrder {
  id               String    @id @default(cuid())
  shopId           String
  customerId       String
  vehicleId        String?
  title            String
  issueDescription String
  vehicleType      String    @default("car")
  serviceLocation  String    @default("in-shop")
  frequency        String
  nextRunAt        DateTime
  lastRunAt        DateTime?
  estimatedCost    Float?
  priority         String    @default("medium")
  notes            String?
  active           Boolean   @default(true)
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  requiresApproval Boolean   @default(true)
  reminder14SentAt DateTime?
  reminder7SentAt  DateTime?
  customer         Customer  @relation(fields: [customerId], references: [id])
  shop             Shop      @relation(fields: [shopId], references: [id])
  vehicle          Vehicle?  @relation(fields: [vehicleId], references: [id])

  @@index([shopId])
  @@index([customerId])
  @@index([nextRunAt])
  @@map("recurring_work_orders")
}

model Bay {
  id          String    @id @default(cuid())
  shopId      String
  name        String
  type        String    @default("general")
  workOrderId String?
  techId      String?
  vehicleDesc String?
  status      String    @default("empty")
  startedAt   DateTime?
  notes       String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  Shop        Shop      @relation(fields: [shopId], references: [id])

  @@index([shopId])
  @@map("bays")
}

model LoanerVehicle {
  id           String    @id @default(cuid())
  shopId       String
  make         String
  model        String
  year         Int
  color        String?
  licensePlate String?
  vin          String?
  mileageOut   Int?
  mileageIn    Int?
  fuelLevelOut String?
  fuelLevelIn  String?
  damageNotes  String?
  photos       String?
  customerId   String?
  workOrderId  String?
  checkedOutAt DateTime?
  expectedBack DateTime?
  checkedInAt  DateTime?
  status       String    @default("available")
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  Shop         Shop      @relation(fields: [shopId], references: [id])

  @@index([shopId])
  @@index([status])
  @@map("loaner_vehicles")
}

model FleetAccount {
  id             String         @id @default(cuid())
  shopId         String
  companyName    String
  contactName    String
  contactEmail   String
  contactPhone   String?
  billingAddress String?
  taxId          String?
  netTerms       Int            @default(30)
  creditLimit    Float          @default(0)
  notes          String?
  status         String         @default("active")
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  Shop           Shop           @relation(fields: [shopId], references: [id])
  invoices       FleetInvoice[]
  vehicles       FleetVehicle[]

  @@index([shopId])
  @@map("fleet_accounts")
}

model FleetVehicle {
  id             String       @id @default(cuid())
  fleetAccountId String
  make           String
  model          String
  year           Int
  vin            String?
  licensePlate   String?
  unitNumber     String?
  mileage        Int?
  notes          String?
